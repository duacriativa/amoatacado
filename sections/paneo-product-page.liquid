{% assign current_product = product %}

<section class="pp-wrap">

  <!-- Imagens -->
  <div class="pp-images">
    {% if current_product.images.size > 0 %}
      <div class="pp-img-main">
        <img src="{{ current_product.images[0] | img_url: '900x' }}" alt="{{ current_product.images[0].alt | escape }}" id="pp-main-img">
      </div>
      {% if current_product.images.size > 1 %}
        <div class="pp-img-thumbs">
          {% for image in current_product.images limit: 5 %}
            <img src="{{ image | img_url: '200x' }}" alt="{{ image.alt | escape }}"
              class="pp-thumb{% if forloop.first %} active{% endif %}"
              onclick="ppSetImage('{{ image | img_url: '900x' }}', this)">
          {% endfor %}
        </div>
      {% endif %}
    {% else %}
      <div class="pp-img-placeholder"><span>PANEÔ</span></div>
    {% endif %}
  </div>

  <!-- Informações -->
  <div class="pp-info">
    <span class="p-label">{{ current_product.vendor }} · Atacado</span>
    <h1 class="pp-title">{{ current_product.title }}</h1>

    <div class="pp-price-block">
      <span class="pp-price">R$ {{ section.settings.wholesale_price | default: 145 }},00</span>
      <span class="pp-price-note">por peça · mínimo {{ section.settings.moq | default: 6 }} peças</span>
    </div>

    <!-- Grade de Quantidade -->
    <div class="pp-opt">
      <div class="pp-grade-header">
        <label class="pp-opt-lbl">Monte sua grade</label>
        <span class="pp-grade-counter">
          <span id="pp-total">0</span> / {{ section.settings.moq | default: 6 }} peças
        </span>
      </div>

      <!-- Tabela Desktop -->
      <div class="pp-grade-table-wrap" id="pp-grade-desktop">
        <table class="pp-grade-table">
          <thead>
            <tr>
              <th></th>
              {% assign color_option = current_product.options_by_name['Cor'] %}
              {% for color in color_option.values %}
                {% assign color_lower = color | downcase %}
                {% if color_lower == 'preto' %}{% assign hex = '#1A1A1A' %}
                {% elsif color_lower == 'bronze' %}{% assign hex = '#7A4A28' %}
                {% elsif color_lower == 'capuccino' or color_lower == 'cappuccino' %}{% assign hex = '#A87848' %}
                {% elsif color_lower == 'azul-marinho' or color_lower == 'azul marinho' %}{% assign hex = '#1B2A4A' %}
                {% elsif color_lower == 'café' or color_lower == 'cafe' %}{% assign hex = '#5C3D2E' %}
                {% elsif color_lower == 'pink' %}{% assign hex = '#E8A0A0' %}
                {% elsif color_lower == 'pérola' or color_lower == 'perola' %}{% assign hex = '#F0EAD6; border: 1px solid #D4C8BC' %}
                {% else %}{% assign hex = '#888' %}
                {% endif %}
                <th>
                  <div class="pp-th-color">
                    <span class="pp-color-dot" style="background:{{ hex }}"></span>
                    {{ color }}
                  </div>
                </th>
              {% endfor %}
              <th class="pp-th-total">Total</th>
            </tr>
          </thead>
          <tbody>
            {% assign size_option = current_product.options_by_name['Tamanho'] %}
            {% for size in size_option.values %}
              <tr>
                <td class="pp-size-label">{{ size }}</td>
                {% for color in color_option.values %}
                  <td class="pp-cell">
                    <div class="pp-cell-inner">
                      <button type="button" class="pp-cell-btn" onclick="ppGradeChange('{{ size }}','{{ color }}',-1)">−</button>
                      <span class="pp-cell-qty" id="qty-{{ size }}-{{ color | replace: ' ', '-' }}">0</span>
                      <button type="button" class="pp-cell-btn" onclick="ppGradeChange('{{ size }}','{{ color }}',1)">+</button>
                    </div>
                  </td>
                {% endfor %}
                <td class="pp-row-total" id="row-{{ size }}">0</td>
              </tr>
            {% endfor %}
          </tbody>
          <tfoot>
            <tr>
              <td class="pp-size-label" style="font-weight:500">Total</td>
              {% for color in color_option.values %}
                <td class="pp-col-total" id="col-{{ color | replace: ' ', '-' }}">0</td>
              {% endfor %}
              <td class="pp-grand-total" id="pp-grand-total">0</td>
            </tr>
          </tfoot>
        </table>
      </div>

      <!-- Progresso -->
      <div class="pp-progress-bar">
        <div class="pp-progress-fill" id="pp-progress-fill" style="width:0%"></div>
      </div>
    </div>

    <p class="pp-warn" id="pp-warn"></p>

    <div class="pp-btns">
      <button type="button" class="pp-atc-btn" id="pp-atc" onclick="ppAddToCart(false)">Adicionar ao Carrinho</button>
      <button type="button" class="pp-buynow-btn" id="pp-buynow" onclick="ppAddToCart(true)">Comprar Agora →</button>
    </div>

    <!-- Especificações -->
    <div class="pp-specs">
      <div class="pp-spec-row"><span>Composição</span><span>{{ section.settings.spec_composition | default: 'Tecido de alta qualidade' }}</span></div>
      <div class="pp-spec-row"><span>Tamanhos</span><span>P · M · G</span></div>
      <div class="pp-spec-row">
        <span>Cores</span>
        <span>
          {% for color in color_option.values %}{{ color }}{% unless forloop.last %} · {% endunless %}{% endfor %}
        </span>
      </div>
      <div class="pp-spec-row"><span>Disponibilidade</span><span>{{ section.settings.availability | default: 'Pronta entrega' }}</span></div>
      <div class="pp-spec-row"><span>Pagamento</span><span>PIX · Cartão de Crédito</span></div>
    </div>

    {% if current_product.description != blank %}
      <div class="pp-desc">{{ current_product.description }}</div>
    {% endif %}
  </div>
</section>

<!-- Variant map -->
<script>
  const PP_MOQ = {{ section.settings.moq | default: 6 }};
  const PP_GRADE = {};
  const PP_VARIANTS = {};

  {% for variant in current_product.variants %}
    PP_VARIANTS['{{ variant.option2 }}_{{ variant.option1 }}'] = {{ variant.id }};
  {% endfor %}

  function ppSetImage(src, thumb) {
    document.getElementById('pp-main-img').src = src;
    document.querySelectorAll('.pp-thumb').forEach(t => t.classList.remove('active'));
    thumb.classList.add('active');
  }

  function ppGradeChange(size, color, delta) {
    const key = size + '_' + color;
    PP_GRADE[key] = Math.max(0, (PP_GRADE[key] || 0) + delta);
    ppUpdateTotals();
  }

  function ppUpdateTotals() {
    let grand = 0;
    const rowTotals = {};
    const colTotals = {};

    Object.entries(PP_GRADE).forEach(([key, qty]) => {
      if (qty <= 0) return;
      const [size, ...colorParts] = key.split('_');
      const color = colorParts.join('_');
      grand += qty;
      rowTotals[size] = (rowTotals[size] || 0) + qty;
      colTotals[color] = (colTotals[color] || 0) + qty;

      const el = document.getElementById('qty-' + size + '-' + color.replace(/ /g, '-'));
      if (el) el.textContent = qty;
    });

    // Reset all displayed quantities then update
    document.querySelectorAll('.pp-cell-qty').forEach(el => {
      const [,size, ...colorParts] = el.id.split('-');
      // id format: qty-SIZE-COLOR
    });

    // Update all cell displays
    document.querySelectorAll('.pp-cell-qty').forEach(el => {
      const id = el.id; // qty-SIZE-COLOR
      const parts = id.replace('qty-','').split('-');
      const size = parts[0];
      const color = parts.slice(1).join('-');
      const key = size + '_' + color.replace(/-/g, ' ');
      el.textContent = PP_GRADE[key] || 0;
    });

    // Row totals
    document.querySelectorAll('[id^="row-"]').forEach(el => {
      const size = el.id.replace('row-','');
      el.textContent = rowTotals[size] || 0;
    });

    // Col totals
    document.querySelectorAll('[id^="col-"]').forEach(el => {
      const color = el.id.replace('col-','').replace(/-/g, ' ');
      el.textContent = colTotals[color] || 0;
    });

    document.getElementById('pp-total').textContent = grand;
    document.getElementById('pp-grand-total').textContent = grand;

    const pct = Math.min(100, (grand / PP_MOQ) * 100);
    document.getElementById('pp-progress-fill').style.width = pct + '%';

    const atc = document.getElementById('pp-atc');
    const buynow = document.getElementById('pp-buynow');
    const ready = grand >= PP_MOQ;
    atc.disabled = !ready;
    buynow.disabled = !ready;

    if (grand > 0 && !ready) {
      document.getElementById('pp-warn').textContent = 'Adicione mais ' + (PP_MOQ - grand) + ' peça(s) para continuar.';
    } else {
      document.getElementById('pp-warn').textContent = '';
    }
  }

  async function ppAddToCart(buyNow) {
    const items = [];
    Object.entries(PP_GRADE).forEach(([key, qty]) => {
      if (qty <= 0) return;
      const vid = PP_VARIANTS[key];
      if (vid) items.push({ id: vid, quantity: qty });
    });

    if (items.length === 0) return;

    const btn = buyNow ? document.getElementById('pp-buynow') : document.getElementById('pp-atc');
    btn.disabled = true;
    btn.textContent = 'Aguarde...';

    try {
      if (buyNow) await fetch('/cart/clear.js', { method: 'POST' });
      const res = await fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ items })
      });
      if (res.ok) {
        window.location.href = buyNow ? '/checkout' : '/cart';
      } else {
        btn.disabled = false;
        btn.textContent = buyNow ? 'Comprar Agora →' : 'Adicionar ao Carrinho';
        document.getElementById('pp-warn').textContent = 'Erro ao adicionar. Tente novamente.';
      }
    } catch {
      btn.disabled = false;
      btn.textContent = buyNow ? 'Comprar Agora →' : 'Adicionar ao Carrinho';
    }
  }

  // Init
  ppUpdateTotals();
</script>

{% schema %}
{
  "name": "Página do Produto",
  "settings": [
    { "type": "number", "id": "moq", "label": "Pedido mínimo (peças)", "default": 6 },
    { "type": "number", "id": "wholesale_price", "label": "Preço atacado (R$)", "default": 145 },
    { "type": "text", "id": "spec_composition", "label": "Composição", "default": "Tecido de alta qualidade" },
    { "type": "text", "id": "availability", "label": "Disponibilidade", "default": "Pronta entrega" }
  ],
  "presets": [{ "name": "Página do Produto" }]
}
{% endschema %}
